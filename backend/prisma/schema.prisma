generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(TECNICO)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@map("users")
}

model Order {
  id           String   @id @default(cuid())
  orderNumber  String   @unique
  customerName String
  equipment    String
  description  String?
  status       OrderStatus @default(PENDIENTE)
  priority     Priority   @default(NORMAL)
  technicianId String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  technician User @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@map("orders")
}

enum Role {
  TECNICO
  SUPERVISOR
  ADMIN
}

enum OrderStatus {
  PENDIENTE
  EN_PROCESO
  TERMINADA
}

enum Priority {
  NORMAL
  URGENTE
}